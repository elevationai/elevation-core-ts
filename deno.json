{
  "name": "@eai/elevation-core-ts",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "exports": {
    ".": "./index.ts",
    "./types": "./types/index.ts",
    "./events": "./lib/events.ts",
    "./logs": "./lib/logs.ts",
    "./iot": "./lib/iot.ts",
    "./cms": "./lib/cms.ts",
    "./enrollment": "./lib/enrollment.ts",
    "./config": "./lib/config.ts",
    "./touchpoint": "./lib/touchpoint.ts",
    "./utils": "./lib/shared/utils.ts"
  },
  "tasks": {
    "test": "deno test --allow-net --allow-env --allow-read"
  },
  "imports": {
    "@eai/models": "jsr:@eai/models@^1.3.2",
    "@eai/models/AwaitableEmitter": "jsr:@eai/models@^1.3.2/AwaitableEmitter",
    "@std/fs": "https://deno.land/std@0.224.0/fs/mod.ts",
    "@std/jsonc": "jsr:@std/jsonc@^1",
    "@std/path": "https://deno.land/std@0.224.0/path/mod.ts",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing/bdd": "jsr:@std/testing@^1/bdd",
    "@std/testing/time": "jsr:@std/testing@^1/time",
    "socket.io-client": "npm:socket.io-client@^4.8.1"
  },
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "lineWidth": 140,
    "proseWrap": "preserve",
    "nextControlFlowPosition": "nextLine",
    "exclude": ["dist/**"]
  },
  "exclude": [
    "dist/",
    ".temp/"
  ]
}
